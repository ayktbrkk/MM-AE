[preset.0]

name="Android"
platform="Android"
runnable=true
dedicated_server=false
custom_features=""
export_filter="all_resources"
include_filter=""
exclude_filter=""

[preset.0.options]

custom_package/debug=""
custom_package/release=""
packages/unique_name="com.mmae.bandirmayolculugu"
version/code=1
version/name="1.0.0"
screen/orientation=1
screen/hw_acceleration=true
screen/depth=0
screen/driver/opengl3=false
gradle/build/use_gradle_build=false
gradle/build/export_format=0
gradle/build/min_sdk=21
gradle/build/target_sdk=34
architectures/arm64=true
architectures/arm32=true
architectures/x86_64=true
keystore/debug=""
keystore/debug_user=""
keystore/debug_password=""
keystore/release=""
keystore/release_user=""
keystore/release_password=""

# =============================================================================
# KEYSTORE YAPILANDIRMASI (Release imzalama için zorunlu)
# =============================================================================
# 1. keytool ile keystore oluştur:
#    keytool -genkey -v -keystore "builds/release.keystore" -alias bandirma -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Oluşturduktan sonra aşağıdaki 3 alanı Godot Editor > Project > Export > Keystore
#    sekmesinden doldur VEYA bu dosyada doğrudan düzenle:
#
#    keystore/release="builds/release.keystore"
#    keystore/release_user="bandirma"
#    keystore/release_password="<sifre>"
#
# 3. Alternatif: tools/build_android_release_candidate.ps1, keystore bilgilerini
#    artifacts/local/release_signing/release_signing.local.json'dan okur.
#    Bu yöntem şifrelerin cfg'ye yazılmasını engeller.
#
# 4. Debug keystore (Godot varsayılanı kullanılır, genelde boş bırakılır):
#    keystore/debug=""
#    keystore/debug_user=""
#    keystore/debug_password=""
#
# ⚠️ GÜVENLİK: Şifreleri ASLA Git reposuna ekleme!
# =============================================================================

