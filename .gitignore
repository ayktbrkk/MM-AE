# Godot 4+ specific ignores
.godot/
android/

# Godot engine binaries (do not commit)
Godot_v*.exe
godot_check.txt
*.dmp

# Unity artifacts (migration residue)
Packages/
ProjectSettings/
assets/TutorialInfo/
*.csproj
*.sln

# Kenney asset packs (download separately)
kenney/

# Temporary / generated files
scripts/world_builder.gd_tmp
captures/
$($img.Width)x$($img.Height)
ERROR

# Test çıktıları
godot_*.txt
decision_test_output.txt

# Root-level Godot check output logs (temporary verification artifacts)
check_*.txt
check_*.txt.*
final_check_*.txt
*_output.txt
extension_api.json

# Temporary verification logs (not accepted, use artifacts/logs/accepted/ for permanence)
artifacts/logs/*.json
artifacts/logs/*.csv
artifacts/logs/*.md
artifacts/local/

# Keep accepted logs tracked
!artifacts/logs/accepted/

# Unity remnants (migration reference only, not referenced in code)
assets/Scenes/
assets/Settings/

# OS artifacts
Thumbs.db
.DS_Store

# Build artifacts (APK too large for GitHub)
builds/

# Generated render artifacts
artifacts/renders/**/*.png.import
artifacts/renders/character_ui/
artifacts/renders/flow_check/
artifacts/renders/ui_regression_current/
artifacts/renders/ui_regression_diffs/
